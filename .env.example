# ── LLM Provider ──────────────────────────────────────────────────────────────
# Any OpenAI-compatible endpoint works. Two paths:
#
# Option A: Managed cloud provider (OpenAI, Groq, OpenRouter, etc.)
#   Set LLM_GATEWAY_API_URL to your provider's base URL
#   Set LLM_GATEWAY_API_KEY to your API key
#   Set LLM_GATEWAY_MODEL to a model that supports function calling
#
# Option B: Local model via Ollama (no API key required)
#   Install Ollama: https://ollama.com
#   Pull a model: ollama pull llama3.1
#   Set LLM_GATEWAY_API_URL=http://localhost:11434/v1
#   Set LLM_GATEWAY_API_KEY=ollama
#   Set LLM_GATEWAY_MODEL=llama3.1
#
# The model MUST support OpenAI-compatible function calling (tool_use).
# Test with --dry-run before a full pipeline run.

LLM_GATEWAY_API_KEY=your_api_key_here
LLM_GATEWAY_API_URL=https://your-provider-base-url/v1
LLM_GATEWAY_MODEL=your-model-name

# ── MemClaw ───────────────────────────────────────────────────────────────────
# Managed platform: get your key and tenant ID at https://memclaw.net (free account)
MEMCLAW_API_URL=https://memclaw.net
MEMCLAW_MCP_URL=https://memclaw.net/mcp
MEMCLAW_TRANSPORT=mcp
MEMCLAW_API_KEY=mc_your_key_here

# Your MemClaw tenant ID (shown in the Prism dashboard after sign-up)
MEMCLAW_TENANT_ID=your_tenant_id

# Fleet identifier -- used to namespace all memories written by this pipeline
MEMCLAW_FLEET_ID=memclaw-build-fleet

# The Manager agent runs within the same tenant as the rest of the pipeline.
# It is isolated by tool restrictions only (no memclaw_write), not by a separate tenant.
